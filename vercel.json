{
  "crons": [
    {
      "path": "/api/cron/process-drips",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/daily-ops",
      "schedule": "0 11 * * 1-5"
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
