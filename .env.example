# Required for live lead capture
# Frontend Supabase config for the Vite app
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Required for server-side Harvest API routes
# Optional server-side alias. The Harvest API helper accepts SUPABASE_URL or VITE_SUPABASE_URL.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Harvest lead alerts and confirmation emails
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=Harvest Drone <no-reply@yourdomain.com>
# Legacy fallback still supported by the active Harvest SOURCE engine:
# RESEND_FROM_EMAIL=Harvest Drone <no-reply@yourdomain.com>
REPLY_TO_EMAIL=jake@yourdomain.com
ALERT_EMAIL=jake@yourdomain.com
ADMIN_EMAIL=ops@yourdomain.com
INTERNAL_NOTIFICATION_EMAIL=jake@yourdomain.com
# Legacy fallback still supported by the active Harvest SOURCE engine:
# NOTIFICATION_EMAIL=jake@yourdomain.com

# Optional: AI summary generation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional: base URL for admin links inside alert emails
APP_BASE_URL=https://yourdomain.com

# Optional: shared enterprise demo login for guarded RDO demo routes.
# Do not commit real passwords. Set these in Vercel/Supabase environment settings.
DEMO_ACCESS_ENABLED=false
DEMO_ACCESS_EMAIL=rdo-demo@yourdomain.com
DEMO_ACCESS_PASSWORD=
DEMO_ACCESS_LABEL=RDO enterprise demo access
DEMO_ACCESS_NAME=RDO Demo User
DEMO_ACCESS_ROLE=dealer

# Optional: operating stack integrations
# Jobber owns CRM/job scheduling/quotes/invoices. Harvest OS logs webhooks and maps external IDs.
JOBBER_ACCESS_TOKEN=
JOBBER_CLIENT_SECRET=
JOBBER_WEBHOOK_SECRET=
JOBBER_GRAPHQL_URL=https://api.getjobber.com/api/graphql

# Twilio SMS. Real sends are disabled unless ENABLE_REAL_SMS=true.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TEST_TO_NUMBER=
TWILIO_STATUS_CALLBACK_URL=
ENABLE_REAL_SMS=false
TWILIO_ENABLE_REAL_SEND=false

# Slack internal alerts. Do not hardcode webhook URLs in code.
SLACK_WEBHOOK_URL=
SLACK_DEFAULT_CHANNEL=
SLACK_DAILY_OPS_WEBHOOK_URL=
SLACK_DAILY_OPS_CHANNEL=#daily-ops
DAILY_OPS_ENABLE_SLACK=false

# Google Workspace read-only foundation for Harvest Daily Ops.
# GOOGLE_REDIRECT_URI should point to /api/admin/google-oauth?action=callback.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/admin/google-oauth?action=callback
GOOGLE_TOKEN_ENCRYPTION_KEY=replace-with-a-long-random-string
DAILY_OPS_TIMEZONE=America/Chicago

# QuickBooks is expected to sync through Jobber first.
QUICKBOOKS_REPORTING_ENABLED=false

# Optional: Meta Pixel config
NEXT_PUBLIC_META_PIXEL_ID=
VITE_META_PIXEL_ID=

# Legacy optional integrations still present elsewhere in the repo
MAILCHIMP_API_KEY=your-mailchimp-api-key
MAILCHIMP_SERVER_PREFIX=us21
MAILCHIMP_LIST_ID=your-mailchimp-audience-id
CRON_SECRET=replace-with-a-long-random-string
